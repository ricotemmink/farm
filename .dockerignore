# =============================================================================
# Consolidated .dockerignore -- applies to all Docker builds from repo root
# =============================================================================
# Both backend and web images build with context: . (repo root).
# Backend needs: pyproject.toml, uv.lock, src/
# Web needs: web/

# Git
.git/
.github/
.gitignore

# Docker configs (Dockerfiles read via -f, not from context)
# Sidecar is un-excluded because its Dockerfile copies Go source from docker/sidecar/.
docker/
!docker/sidecar/
!docker/sandbox/healthz.py

# Tests
tests/

# Documentation -- re-included for docs builder stage in web Dockerfile
docs/
*.md
!docs/

# Documentation build output (Zensical)
_site/

# Astro landing page (not needed by any Docker build)
site/

# Virtual environments
.venv/
venv/

# Python caches
__pycache__/
*.py[cod]
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Hypothesis test database
.hypothesis/

# Coverage
htmlcov/
coverage.xml
.coverage
.coverage.*

# Databases
*.db
*.sqlite3

# Environment files
.env
.env.*

# IDE
.idea/
.vscode/

# CI/build utility scripts (not needed in Docker builds)
scripts/
!scripts/export_openapi.py

# CLI (Go binary, not needed in Docker builds)
cli/

# Claude Code config
.claude/

# Logs
logs/
*.log

# OS files
Thumbs.db
.DS_Store

# Web dashboard build artifacts and test infrastructure
web/node_modules/
web/dist/
web/.env
web/__tests__/
web/vitest.config.*

# uv
.python-version
