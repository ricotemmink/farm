---
import Base from "../../../layouts/Base.astro";
import fs from "node:fs";
import path from "node:path";

const scriptPath = path.resolve("../cli/scripts/install.ps1");
const content = fs.readFileSync(scriptPath, "utf-8");
---

<Base title="install.ps1 — SynthOrg CLI Installer">
  <section class="pt-16 pb-10 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold mb-1">install.ps1</h1>
          <p class="text-sm text-gray-400">Windows (PowerShell) install script</p>
        </div>
        <div class="flex gap-3">
          <a
            href="/get/install.ps1"
            download
            class="inline-flex items-center px-4 py-2 bg-violet-600 hover:bg-violet-500 rounded-lg text-sm font-semibold transition-colors"
          >
            Download
          </a>
          <a
            href="/get/"
            class="inline-flex items-center px-4 py-2 border border-white/20 hover:border-white/40 rounded-lg text-sm text-gray-300 transition-colors"
          >
            Back
          </a>
        </div>
      </div>
      <div class="bg-[#0d1117] rounded-xl border border-white/10 overflow-hidden">
        <div class="flex items-center px-4 py-2 bg-[#161b22] border-b border-white/10">
          <div class="flex items-center gap-1">
            <span class="text-xs text-gray-400 font-mono">install.ps1</span>
          </div>
          <div class="ml-auto flex items-center gap-2.5 text-gray-600 text-xs leading-none">
            <span>&#x2500;</span>
            <span>&#x25A1;</span>
            <span>&#x2715;</span>
          </div>
        </div>
        <pre class="p-4 text-sm font-['JetBrains_Mono',monospace] text-gray-300 overflow-x-auto leading-relaxed"><code>{content}</code></pre>
      </div>
    </div>
  </section>
</Base>
