---
import Base from "../layouts/Base.astro";
---

<Base title="SynthOrg — Build Synthetic Organizations">
  <!-- ============================================================ -->
  <!-- HERO (Dark) -->
  <!-- ============================================================ -->
  <section class="relative min-h-screen flex items-center justify-center px-6">
    <!-- TODO: Animated particle network background (Canvas island) -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0F1219] via-[#1a1025] to-[#0F1219]"></div>

    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <!-- Eyebrow -->
      <p class="text-sm tracking-widest text-violet-400 mb-6 font-mono">
        Python 3.14+ &middot; BSL 1.1 &middot; Open Source
      </p>

      <!-- Headline -->
      <h1 class="text-5xl md:text-7xl font-bold leading-tight mb-6">
        What if your company had
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-teal-400">
          infinite, tireless employees?
        </span>
      </h1>

      <!-- Subtext -->
      <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-10">
        SynthOrg is a Python framework for building synthetic organizations &mdash;
        autonomous AI agents with roles, budgets, memory, and governance. Open source.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/docs/getting_started/"
          class="px-8 py-3 bg-violet-600 hover:bg-violet-500 rounded-lg font-semibold transition-colors"
        >
          Start Building
        </a>
        <a
          href="#how-it-works"
          class="px-8 py-3 border border-teal-400/50 text-teal-400 hover:bg-teal-400/10 rounded-lg font-semibold transition-colors"
        >
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- PROOF STRIP -->
  <!-- ============================================================ -->
  <section class="py-8 border-y border-white/10">
    <div class="max-w-5xl mx-auto flex flex-wrap justify-center gap-8 text-sm text-gray-400">
      <span class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-violet-400"></span> Type-Safe
      </span>
      <span class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-teal-400"></span> Async-First
      </span>
      <span class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-violet-400"></span> Protocol-Driven
      </span>
      <span class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-teal-400"></span> Provider-Agnostic
      </span>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- HOW IT WORKS — Split Panel -->
  <!-- ============================================================ -->
  <section id="how-it-works" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">See How It Works</h2>

      <div class="grid md:grid-cols-2 gap-12 items-start">
        <!-- Code side -->
        <div class="bg-[#1a1f2e] rounded-xl p-6 border border-white/10">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
            <span class="ml-3 text-sm text-gray-500 font-mono">company.yaml</span>
          </div>
          <pre class="text-sm font-['JetBrains_Mono',monospace] text-gray-300 overflow-x-auto"><code><span class="text-violet-400">company</span>:
  <span class="text-teal-400">name</span>: "Acme AI Lab"

<span class="text-violet-400">agents</span>:
  - <span class="text-teal-400">name</span>: "CTO"
    <span class="text-teal-400">role</span>: tech_lead
    <span class="text-teal-400">model</span>: large
    <span class="text-teal-400">budget</span>:
      <span class="text-teal-400">max_daily_usd</span>: 50.00

  - <span class="text-teal-400">name</span>: "Engineer"
    <span class="text-teal-400">role</span>: developer
    <span class="text-teal-400">model</span>: medium
    <span class="text-teal-400">reports_to</span>: "CTO"
    <span class="text-teal-400">tools</span>:
      - file_system
      - git
      - code_runner</code></pre>
        </div>

        <!-- Description side -->
        <!-- TODO: Replace with animated agent visualization (Vue/React island) -->
        <div class="space-y-8">
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-lg bg-violet-600/20 flex items-center justify-center text-violet-400 font-bold shrink-0">1</div>
            <div>
              <h3 class="font-semibold text-lg mb-1">Define your organization</h3>
              <p class="text-gray-400">Describe agents, roles, hierarchy, budgets, and tools in a YAML config file.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-lg bg-violet-600/20 flex items-center justify-center text-violet-400 font-bold shrink-0">2</div>
            <div>
              <h3 class="font-semibold text-lg mb-1">The engine orchestrates</h3>
              <p class="text-gray-400">Tasks are decomposed, routed to agents, and executed with conflict resolution and budget checks.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-lg bg-violet-600/20 flex items-center justify-center text-violet-400 font-bold shrink-0">3</div>
            <div>
              <h3 class="font-semibold text-lg mb-1">Observe and control</h3>
              <p class="text-gray-400">Structured logs, cost tracking, security audit trails, and performance metrics — all built in.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- CORE PILLARS (transition to lighter) -->
  <!-- ============================================================ -->
  <section class="py-24 px-6 bg-gradient-to-b from-[#0F1219] to-[#1a1f2e]">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">Core Pillars</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Orchestration -->
        <div class="bg-[#0F1219] rounded-xl p-8 border border-violet-500/20 hover:border-violet-500/40 transition-colors">
          <div class="w-12 h-12 rounded-lg bg-violet-600/20 flex items-center justify-center text-violet-400 mb-4 text-xl">&#9881;</div>
          <h3 class="text-xl font-semibold mb-3">Orchestration</h3>
          <p class="text-gray-400 mb-4">Define agents with roles, models, and tools. The engine handles task decomposition, routing, conflict resolution, and collaboration.</p>
          <ul class="text-sm text-gray-500 space-y-1">
            <li>3 execution loops (ReAct, Plan-and-Execute, Hybrid)</li>
            <li>DAG-based task decomposition</li>
            <li>5 routing strategies</li>
          </ul>
        </div>

        <!-- Governance -->
        <div class="bg-[#0F1219] rounded-xl p-8 border border-teal-500/20 hover:border-teal-500/40 transition-colors">
          <div class="w-12 h-12 rounded-lg bg-teal-600/20 flex items-center justify-center text-teal-400 mb-4 text-xl">&#128274;</div>
          <h3 class="text-xl font-semibold mb-3">Governance</h3>
          <p class="text-gray-400 mb-4">Built-in security, budget enforcement, and progressive trust. The SecOps agent and fail-closed rule engine protect every action.</p>
          <ul class="text-sm text-gray-500 space-y-1">
            <li>4 trust strategies</li>
            <li>Per-agent budget limits + auto-downgrade</li>
            <li>Approval timeout policies</li>
          </ul>
        </div>

        <!-- Memory -->
        <div class="bg-[#0F1219] rounded-xl p-8 border border-violet-500/20 hover:border-violet-500/40 transition-colors">
          <div class="w-12 h-12 rounded-lg bg-violet-600/20 flex items-center justify-center text-violet-400 mb-4 text-xl">&#129504;</div>
          <h3 class="text-xl font-semibold mb-3">Memory</h3>
          <p class="text-gray-400 mb-4">Per-agent and shared organizational memory. Retrieval pipeline with ranking, filtering, and context injection. Consolidation and archival.</p>
          <ul class="text-sm text-gray-500 space-y-1">
            <li>Pluggable memory backends</li>
            <li>Shared org knowledge base</li>
            <li>Automatic memory consolidation</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- EXPANDABLE ARCHITECTURE -->
  <!-- ============================================================ -->
  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Architecture</h2>
      <p class="text-gray-400 mb-12">Modular, protocol-driven. Every component is pluggable.</p>

      <!-- TODO: Make this expandable (Vue/React island) -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-[#1a1f2e] rounded-xl p-6 border border-white/10">
          <p class="font-semibold text-violet-400">Config</p>
          <p class="text-xs text-gray-500 mt-1">YAML schema, loader, validation</p>
        </div>
        <div class="bg-[#1a1f2e] rounded-xl p-6 border border-white/10">
          <p class="font-semibold text-violet-400">Engine</p>
          <p class="text-xs text-gray-500 mt-1">Loops, decomposition, routing</p>
        </div>
        <div class="bg-[#1a1f2e] rounded-xl p-6 border border-white/10">
          <p class="font-semibold text-violet-400">Agents</p>
          <p class="text-xs text-gray-500 mt-1">HR, comms, tools, memory</p>
        </div>
        <div class="bg-[#1a1f2e] rounded-xl p-6 border border-white/10">
          <p class="font-semibold text-violet-400">Infra</p>
          <p class="text-xs text-gray-500 mt-1">Providers, persistence, observability</p>
        </div>
      </div>

      <a href="/docs/architecture/" class="inline-block mt-8 text-teal-400 hover:text-teal-300 transition-colors">
        Explore full architecture &rarr;
      </a>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- USE CASES -->
  <!-- ============================================================ -->
  <section class="py-24 px-6 bg-gradient-to-b from-[#0F1219] to-[#1a1025]">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">Use Cases</h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-[#0F1219] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors">
          <p class="text-violet-400 font-semibold mb-2">AI Dev Team</p>
          <p class="text-sm text-gray-400">CTO + Engineers + QA. Autonomous software development with code review and testing.</p>
        </div>
        <div class="bg-[#0F1219] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors">
          <p class="text-violet-400 font-semibold mb-2">Research Org</p>
          <p class="text-sm text-gray-400">Director + Analysts + Reviewers. Literature review, data analysis, and report generation.</p>
        </div>
        <div class="bg-[#0F1219] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors">
          <p class="text-violet-400 font-semibold mb-2">Content Pipeline</p>
          <p class="text-sm text-gray-400">Editor + Writers + Fact-checkers. Content creation with editorial oversight and quality control.</p>
        </div>
        <div class="bg-[#0F1219] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors">
          <p class="text-violet-400 font-semibold mb-2">Support Org</p>
          <p class="text-sm text-gray-400">Manager + Agents + Escalation. Customer support with tiered handling and knowledge sharing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- OPEN SOURCE (dark) -->
  <!-- ============================================================ -->
  <section class="py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Open Source</h2>
      <p class="text-gray-400 mb-8">
        BSL 1.1 &mdash; converts to Apache 2.0 on 2030-02-27.
        Our <a href="https://github.com/Aureliolo/synthorg/blob/main/DESIGN_SPEC.md" class="text-teal-400 hover:underline">3500-line design specification</a> is public.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://github.com/Aureliolo/synthorg"
          class="px-8 py-3 bg-white/10 hover:bg-white/15 rounded-lg font-semibold transition-colors"
        >
          Star on GitHub
        </a>
        <a
          href="/docs/"
          class="px-8 py-3 border border-white/20 hover:bg-white/5 rounded-lg font-semibold transition-colors"
        >
          Read the Documentation
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FINAL CTA -->
  <!-- ============================================================ -->
  <section class="py-24 px-6 bg-gradient-to-b from-[#0F1219] to-[#1a1025]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-bold mb-6">
        Build something that thinks
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-teal-400">like a team.</span>
      </h2>

      <div class="bg-[#1a1f2e] rounded-xl p-4 max-w-md mx-auto mb-8 border border-white/10">
        <code class="font-['JetBrains_Mono',monospace] text-sm text-gray-300">
          <span class="text-gray-500">$</span> git clone https://github.com/Aureliolo/synthorg &amp;&amp; uv sync
        </code>
      </div>

      <a
        href="/docs/getting_started/"
        class="inline-block px-10 py-4 bg-violet-600 hover:bg-violet-500 rounded-lg font-semibold text-lg transition-colors"
      >
        Get Started
      </a>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FOOTER -->
  <!-- ============================================================ -->
  <footer class="py-12 px-6 border-t border-white/10">
    <div class="max-w-6xl mx-auto grid sm:grid-cols-4 gap-8 text-sm">
      <div>
        <p class="font-semibold mb-3">Framework</p>
        <ul class="space-y-2 text-gray-400">
          <li><a href="/docs/api/core/" class="hover:text-white transition-colors">Core Models</a></li>
          <li><a href="/docs/api/engine/" class="hover:text-white transition-colors">Engine</a></li>
          <li><a href="/docs/api/providers/" class="hover:text-white transition-colors">Providers</a></li>
          <li><a href="/docs/api/tools/" class="hover:text-white transition-colors">Tools</a></li>
        </ul>
      </div>
      <div>
        <p class="font-semibold mb-3">Learn</p>
        <ul class="space-y-2 text-gray-400">
          <li><a href="/docs/" class="hover:text-white transition-colors">Documentation</a></li>
          <li><a href="/docs/getting_started/" class="hover:text-white transition-colors">Getting Started</a></li>
          <li><a href="/docs/architecture/" class="hover:text-white transition-colors">Architecture</a></li>
          <li><a href="https://github.com/Aureliolo/synthorg/blob/main/DESIGN_SPEC.md" class="hover:text-white transition-colors">Design Spec</a></li>
        </ul>
      </div>
      <div>
        <p class="font-semibold mb-3">Community</p>
        <ul class="space-y-2 text-gray-400">
          <li><a href="https://github.com/Aureliolo/synthorg" class="hover:text-white transition-colors">GitHub</a></li>
          <li><a href="https://github.com/Aureliolo/synthorg/blob/main/.github/CHANGELOG.md" class="hover:text-white transition-colors">Changelog</a></li>
        </ul>
      </div>
      <div>
        <p class="font-semibold mb-3">Legal</p>
        <ul class="space-y-2 text-gray-400">
          <li><a href="https://github.com/Aureliolo/synthorg/blob/main/LICENSE" class="hover:text-white transition-colors">License (BSL 1.1)</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 pt-8 border-t border-white/10 text-center text-gray-500 text-xs">
      &copy; 2026 SynthOrg. Built with Astro.
    </div>
  </footer>
</Base>
