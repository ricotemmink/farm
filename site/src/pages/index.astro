---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.astro";

const description = "Framework for building synthetic organizations — autonomous AI agents orchestrated as a virtual company";
---

<Base title="SynthOrg — Build Synthetic Organizations" description={description}>
  <!-- ============================================================ -->
  <!-- HERO (Dark) -->
  <!-- ============================================================ -->
  <section class="relative min-h-[85vh] flex items-center justify-center px-6">
    <!-- TODO: Animated particle network background (Canvas island) -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0F1219] via-[#1a1025] to-[#0F1219]"></div>

    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <!-- Eyebrow -->
      <p class="text-sm tracking-widest text-violet-400 mb-6 font-mono">
        Python 3.14+ &middot; BSL 1.1 &middot; Source Available
      </p>

      <!-- Headline -->
      <h1 class="text-5xl md:text-7xl font-bold leading-tight mb-6">
        What if your company had
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-teal-400">
          infinite, tireless employees?
        </span>
      </h1>

      <!-- Subtext -->
      <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-10">
        SynthOrg is a Python framework for building synthetic organizations &mdash;
        autonomous AI agents with roles, budgets, memory, and governance. Source-available under BSL 1.1.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="/get/"
          class="px-8 py-3 bg-violet-600 hover:bg-violet-500 rounded-lg font-semibold transition-colors"
        >
          Start Building
        </a>
        <a
          href="#license-usage"
          class="px-8 py-3 border border-teal-400/50 text-teal-400 hover:bg-teal-400/10 rounded-lg font-semibold transition-colors"
        >
          License & Usage Restrictions
        </a>
        <a class="github-button" href="https://github.com/Aureliolo/synthorg" data-icon="octicon-star" data-size="large" data-show-count="true" aria-label="Star Aureliolo/synthorg on GitHub">Star</a>
      </div>

      <!-- Scroll hint -->
      <a href="#how-it-works" class="mt-12 inline-block text-gray-400 hover:text-gray-300 transition-colors animate-bounce" aria-label="Scroll down for more details">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </a>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- EARLY-ACCESS DISCLAIMER -->
  <!-- ============================================================ -->
  <section class="py-4 px-6 bg-gradient-to-r from-violet-600/10 via-teal-600/10 to-violet-600/10 border-y border-violet-500/20">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm text-gray-300">
        <span class="font-semibold text-violet-400">Early Access</span> —
        SynthOrg is under active development. Some features shown are planned but not yet fully implemented.
        <a href="https://github.com/Aureliolo/synthorg" class="text-teal-400 underline decoration-teal-400/40 hover:decoration-teal-400">Follow on GitHub</a> ·
        <a href="#contact" class="text-teal-400 underline decoration-teal-400/40 hover:decoration-teal-400">Get in touch</a>
      </p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- PROOF STRIP -->
  <!-- ============================================================ -->
  <section class="py-8 border-y border-white/10">
    <div class="max-w-5xl mx-auto flex flex-wrap justify-center gap-8 text-sm text-gray-400">
      <span class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-violet-400"></span> Type-Safe
      </span>
      <span class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-teal-400"></span> Async-First
      </span>
      <span class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-violet-400"></span> Protocol-Driven
      </span>
      <span class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-teal-400"></span> Provider-Agnostic
      </span>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- HOW IT WORKS — Split Panel -->
  <!-- ============================================================ -->
  <section id="how-it-works" class="py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">See How It Works</h2>

      <div class="grid md:grid-cols-2 gap-12 items-start">
        <!-- Code side -->
        <div class="bg-[#1a1f2e] rounded-xl p-6 border border-white/10">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
            <span class="ml-3 text-sm text-gray-400 font-mono">company.yaml</span>
          </div>
          <pre class="text-sm font-['JetBrains_Mono',monospace] text-gray-300 overflow-x-auto"><code><span class="text-violet-400">company</span>:
  <span class="text-teal-400">name</span>: "Acme AI Lab"

<span class="text-violet-400">agents</span>:
  - <span class="text-teal-400">name</span>: "CTO"
    <span class="text-teal-400">role</span>: tech_lead
    <span class="text-teal-400">model</span>: large
    <span class="text-teal-400">budget</span>:
      <span class="text-teal-400">max_daily_usd</span>: 50.00

  - <span class="text-teal-400">name</span>: "Engineer"
    <span class="text-teal-400">role</span>: developer
    <span class="text-teal-400">model</span>: medium
    <span class="text-teal-400">reports_to</span>: "CTO"
    <span class="text-teal-400">tools</span>:
      - file_system
      - git
      - code_runner</code></pre>
        </div>

        <!-- Description side -->
        <!-- TODO: Replace with animated agent visualization (Vue/React island) -->
        <div class="space-y-8">
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-lg bg-violet-600/20 flex items-center justify-center text-violet-400 font-bold shrink-0">1</div>
            <div>
              <h3 class="font-semibold text-lg mb-1">Pick a template or define your own</h3>
              <p class="text-gray-400">Choose a pre-built org template, or describe agents, roles, hierarchy, budgets, and tools through the dashboard.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-lg bg-violet-600/20 flex items-center justify-center text-violet-400 font-bold shrink-0">2</div>
            <div>
              <h3 class="font-semibold text-lg mb-1">The engine orchestrates</h3>
              <p class="text-gray-400">Tasks are decomposed, routed to agents, and executed with conflict resolution and budget checks.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-lg bg-violet-600/20 flex items-center justify-center text-violet-400 font-bold shrink-0">3</div>
            <div>
              <h3 class="font-semibold text-lg mb-1">Observe and control</h3>
              <p class="text-gray-400">Structured logs, cost tracking, security audit trails, and performance metrics — all built in.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- CORE PILLARS (transition to lighter) -->
  <!-- ============================================================ -->
  <section class="py-16 px-6 bg-gradient-to-b from-[#0F1219] to-[#1a1f2e]">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">Core Pillars</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Orchestration -->
        <a href="/docs/design/engine/" class="block bg-[#0F1219] rounded-xl p-8 border border-violet-500/20 hover:border-violet-500/40 transition-colors no-underline text-white">
          <div class="w-12 h-12 rounded-lg bg-violet-600/20 flex items-center justify-center text-violet-400 mb-4 text-xl">&#9881;</div>
          <h3 class="text-xl font-semibold mb-3">Orchestration</h3>
          <p class="text-gray-400 mb-4">Define agents with roles, models, and tools. The engine handles task decomposition, routing, conflict resolution, and collaboration.</p>
          <ul class="text-sm text-gray-400 space-y-1">
            <li>3 execution loops (ReAct, Plan-and-Execute, Hybrid)</li>
            <li>DAG-based task decomposition</li>
            <li>5 routing strategies</li>
          </ul>
        </a>

        <!-- Governance -->
        <a href="/docs/security/" class="block bg-[#0F1219] rounded-xl p-8 border border-teal-500/20 hover:border-teal-500/40 transition-colors no-underline text-white">
          <div class="w-12 h-12 rounded-lg bg-teal-600/20 flex items-center justify-center text-teal-400 mb-4 text-xl">&#128274;</div>
          <h3 class="text-xl font-semibold mb-3">Governance</h3>
          <p class="text-gray-400 mb-4">Built-in security, budget enforcement, and progressive trust. The SecOps agent and fail-closed rule engine protect every action.</p>
          <ul class="text-sm text-gray-400 space-y-1">
            <li>4 trust strategies</li>
            <li>Per-agent budget limits + auto-downgrade</li>
            <li>Approval timeout policies</li>
          </ul>
        </a>

        <!-- Memory -->
        <a href="/docs/design/memory/" class="block bg-[#0F1219] rounded-xl p-8 border border-violet-500/20 hover:border-violet-500/40 transition-colors no-underline text-white">
          <div class="w-12 h-12 rounded-lg bg-violet-600/20 flex items-center justify-center text-violet-400 mb-4 text-xl">&#129504;</div>
          <h3 class="text-xl font-semibold mb-3">Memory</h3>
          <p class="text-gray-400 mb-4">Per-agent and shared organizational memory. Retrieval pipeline with ranking, filtering, and context injection. Consolidation and archival.</p>
          <ul class="text-sm text-gray-400 space-y-1">
            <li>Pluggable memory backends</li>
            <li>Shared org knowledge base</li>
            <li>Automatic memory consolidation</li>
          </ul>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- EXPANDABLE ARCHITECTURE -->
  <!-- ============================================================ -->
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Architecture</h2>
      <p class="text-gray-400 mb-12">Modular, protocol-driven. Every component is pluggable.</p>

      <!-- TODO: Make this expandable (Vue/React island) -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/docs/design/organization/" class="block bg-[#1a1f2e] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors no-underline">
          <p class="font-semibold text-violet-400">Config</p>
          <p class="text-xs text-gray-400 mt-1">YAML schema, loader, validation</p>
        </a>
        <a href="/docs/design/engine/" class="block bg-[#1a1f2e] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors no-underline">
          <p class="font-semibold text-violet-400">Engine</p>
          <p class="text-xs text-gray-400 mt-1">Loops, decomposition, routing</p>
        </a>
        <a href="/docs/design/agents/" class="block bg-[#1a1f2e] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors no-underline">
          <p class="font-semibold text-violet-400">Agents</p>
          <p class="text-xs text-gray-400 mt-1">HR, comms, tools, memory</p>
        </a>
        <a href="/docs/architecture/" class="block bg-[#1a1f2e] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors no-underline">
          <p class="font-semibold text-violet-400">Infra</p>
          <p class="text-xs text-gray-400 mt-1">Providers, persistence, observability</p>
        </a>
      </div>

      <a href="/docs/architecture/" class="inline-block mt-8 text-teal-400 underline decoration-teal-400/40 hover:decoration-teal-400 transition-colors">
        Explore full architecture &rarr;
      </a>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SECURITY -->
  <!-- ============================================================ -->
  <section class="py-16 px-6 bg-gradient-to-b from-[#0F1219] to-[#1a1025]">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Security-First by Design</h2>
      <p class="text-gray-400 text-center max-w-2xl mx-auto mb-16">
        Autonomous agents need guardrails. SynthOrg embeds security at every layer &mdash;
        from the application runtime to the CI/CD pipeline and container infrastructure.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Runtime Security -->
        <a href="/docs/security/#application-security" class="block bg-[#0F1219] rounded-xl p-8 border border-teal-500/20 hover:border-teal-500/40 transition-colors no-underline text-white">
          <div class="w-12 h-12 rounded-lg bg-teal-600/20 flex items-center justify-center text-teal-400 mb-4 text-xl">&#128737;</div>
          <h3 class="text-xl font-semibold mb-3">Runtime Protection</h3>
          <p class="text-gray-400 mb-4">Every tool invocation passes through a fail-closed rule engine before execution. Five detectors scan for credentials, path traversal, destructive operations, and data leaks.</p>
          <ul class="text-sm text-gray-400 space-y-1">
            <li>SecOps agent with fail-closed rule engine</li>
            <li>Output scanning with redaction policies</li>
            <li>Progressive trust &amp; approval workflows</li>
            <li>Persistent audit trail for every decision</li>
          </ul>
        </a>

        <!-- Container & Supply Chain -->
        <a href="/docs/security/#container-hardening" class="block bg-[#0F1219] rounded-xl p-8 border border-teal-500/20 hover:border-teal-500/40 transition-colors no-underline text-white">
          <div class="w-12 h-12 rounded-lg bg-teal-600/20 flex items-center justify-center text-teal-400 mb-4 text-xl">&#128230;</div>
          <h3 class="text-xl font-semibold mb-3">Hardened Infrastructure</h3>
          <p class="text-gray-400 mb-4">Distroless containers, digest-pinned images, and CIS Docker Benchmark compliance. Every image is scanned by two tools and signed before push.</p>
          <ul class="text-sm text-gray-400 space-y-1">
            <li>Chainguard distroless runtime (no shell)</li>
            <li>Trivy + Grype dual scanning</li>
            <li>cosign keyless image signing</li>
            <li>CIS 5.3 / 5.12 / 5.25 compliance</li>
          </ul>
        </a>

        <!-- CI/CD Security -->
        <a href="/docs/security/#cicd-security" class="block bg-[#0F1219] rounded-xl p-8 border border-teal-500/20 hover:border-teal-500/40 transition-colors no-underline text-white">
          <div class="w-12 h-12 rounded-lg bg-teal-600/20 flex items-center justify-center text-teal-400 mb-4 text-xl">&#9889;</div>
          <h3 class="text-xl font-semibold mb-3">Continuous Security</h3>
          <p class="text-gray-400 mb-4">Eight security scanners run across the development lifecycle. Secret detection, SAST, DAST, dependency auditing, license compliance, and supply chain scoring.</p>
          <ul class="text-sm text-gray-400 space-y-1">
            <li>gitleaks, CodeQL, ZAP DAST, zizmor</li>
            <li>pip-audit + npm audit + Socket.dev</li>
            <li>OSSF Scorecard supply chain maturity</li>
            <li>Signed commits + required reviews</li>
          </ul>
        </a>
      </div>

      <div class="text-center mt-10">
        <a href="/docs/security/" class="text-teal-400 underline decoration-teal-400/40 hover:decoration-teal-400 transition-colors">
          Read the full security documentation &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- USE CASES -->
  <!-- ============================================================ -->
  <section class="py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">Use Cases</h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-[#0F1219] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors">
          <p class="text-violet-400 font-semibold mb-2">AI Dev Team</p>
          <p class="text-sm text-gray-400">CTO + Engineers + QA. Autonomous software development with code review and testing.</p>
        </div>
        <div class="bg-[#0F1219] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors">
          <p class="text-violet-400 font-semibold mb-2">Research Org</p>
          <p class="text-sm text-gray-400">Director + Analysts + Reviewers. Literature review, data analysis, and report generation.</p>
        </div>
        <div class="bg-[#0F1219] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors">
          <p class="text-violet-400 font-semibold mb-2">Content Pipeline</p>
          <p class="text-sm text-gray-400">Editor + Writers + Fact-checkers. Content creation with editorial oversight and quality control.</p>
        </div>
        <div class="bg-[#0F1219] rounded-xl p-6 border border-white/10 hover:border-violet-500/30 transition-colors">
          <p class="text-violet-400 font-semibold mb-2">Support Org</p>
          <p class="text-sm text-gray-400">Manager + Agents + Escalation. Customer support with tiered handling and knowledge sharing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- LICENSE & USAGE -->
  <!-- ============================================================ -->
  <section id="license-usage" class="py-16 px-6 bg-gradient-to-b from-[#1a1f2e] to-[#0F1219]">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">License & Usage</h2>
      <p class="text-gray-400 text-center max-w-2xl mx-auto mb-16">
        SynthOrg uses the <a href="https://github.com/Aureliolo/synthorg/blob/main/LICENSE" class="text-teal-400 underline decoration-teal-400/40 hover:decoration-teal-400">Business Source License 1.1</a>
        &mdash; source available, production-friendly for most users, converting to Apache 2.0 automatically.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Always Free -->
        <div class="bg-[#0F1219] rounded-xl p-8 border border-green-500/20">
          <div class="w-12 h-12 rounded-lg bg-green-600/20 flex items-center justify-center text-green-400 mb-4 text-xl">&#10003;</div>
          <h3 class="text-xl font-semibold mb-3 text-green-400">Always Free</h3>
          <ul class="text-gray-400 space-y-2 text-sm">
            <li>Personal learning and experimentation</li>
            <li>Academic and research use</li>
            <li>Development, testing, and evaluation</li>
            <li>Contributing to SynthOrg itself</li>
          </ul>
        </div>

        <!-- Free in Production -->
        <div class="bg-[#0F1219] rounded-xl p-8 border border-teal-500/20">
          <div class="w-12 h-12 rounded-lg bg-teal-600/20 flex items-center justify-center text-teal-400 mb-4 text-xl">&#10003;</div>
          <h3 class="text-xl font-semibold mb-3 text-teal-400">Free in Production</h3>
          <ul class="text-gray-400 space-y-2 text-sm">
            <li>Organizations with &lt;500 employees and contractors (including affiliates)</li>
            <li>Non-competing use: internal tools, automation, or products where SynthOrg is not the core value</li>
            <li>No separate license needed &mdash; see <a href="https://github.com/Aureliolo/synthorg/blob/main/LICENSE" class="text-teal-400 underline decoration-teal-400/40 hover:decoration-teal-400">LICENSE</a> for full terms</li>
          </ul>
        </div>

        <!-- Commercial License -->
        <div class="bg-[#0F1219] rounded-xl p-8 border border-violet-500/20">
          <div class="w-12 h-12 rounded-lg bg-violet-600/20 flex items-center justify-center text-violet-400 mb-4 text-xl">&#9993;</div>
          <h3 class="text-xl font-semibold mb-3 text-violet-400">Commercial License</h3>
          <ul class="text-gray-400 space-y-2 text-sm">
            <li>Organizations with 500+ employees</li>
            <li>Offering SynthOrg as a hosted service</li>
            <li>Reselling or embedding as core product</li>
            <li>May be granted at no cost &mdash; just ask</li>
          </ul>
        </div>
      </div>

      <div class="text-center mt-10">
        <p class="text-gray-400 text-sm mb-4">
          Every version converts to Apache 2.0 automatically. We welcome feedback on the license &mdash;
          <a href="https://github.com/Aureliolo/synthorg/discussions" class="text-teal-400 underline decoration-teal-400/40 hover:decoration-teal-400">start a discussion</a> or
          <a href="https://github.com/Aureliolo/synthorg/issues" class="text-teal-400 underline decoration-teal-400/40 hover:decoration-teal-400">open an issue</a>.
        </p>
        <a href="/docs/licensing/" class="text-teal-400 underline decoration-teal-400/40 hover:decoration-teal-400 transition-colors">
          Read the full licensing rationale &rarr;
        </a>

        <div class="flex flex-col sm:flex-row gap-4 items-center justify-center mt-8">
          <div class="flex gap-3">
            <a class="github-button" href="https://github.com/Aureliolo/synthorg" data-icon="octicon-star" data-size="large" data-show-count="true" aria-label="Star Aureliolo/synthorg on GitHub">Star</a>
            <a class="github-button" href="https://github.com/Aureliolo/synthorg/fork" data-icon="octicon-repo-forked" data-size="large" data-show-count="true" aria-label="Fork Aureliolo/synthorg on GitHub">Fork</a>
          </div>
          <a
            href="/docs/"
            class="px-8 py-3 border border-white/20 hover:bg-white/5 rounded-lg font-semibold transition-colors"
          >
            Read the Documentation
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FINAL CTA -->
  <!-- ============================================================ -->
  <section class="py-16 px-6 bg-gradient-to-b from-[#0F1219] to-[#1a1025]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-bold mb-6">
        Build something that thinks
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-teal-400">like a team.</span>
      </h2>

      <a
        href="/get/"
        class="inline-block px-10 py-4 bg-violet-600 hover:bg-violet-500 rounded-lg font-semibold text-lg transition-colors"
      >
        Get Started
      </a>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- CONTACT -->
  <!-- ============================================================ -->
  <section id="contact" class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Get in Touch</h2>
      <p class="text-gray-400 text-center max-w-xl mx-auto mb-10">
        Questions about licensing, commercial use, or the framework? We'd love to hear from you.
      </p>
      <ContactForm />
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FOOTER -->
  <!-- ============================================================ -->
  <Footer />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "SynthOrg",
    "description": description,
    "url": Astro.site,
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Linux, macOS, Windows",
    "license": "https://github.com/Aureliolo/synthorg/blob/main/LICENSE",
