# SynthOrg web dashboard -- served by Caddy from a pure-apko Wolfi image.
# Installed at /etc/synthorg/Caddyfile by docker/web/melange.yaml.
#
# Replicates every behavior of the previous web/nginx.conf:
#   - :8080 unprivileged listen
#   - precompressed gzip (Caddy's file_server directive replaces gzip_static)
#   - per-request CSP nonce via the templates directive +
#     {{placeholder "http.request.uuid"}} (replaces nginx sub_filter + $request_id)
#   - SPA fallback to /index.html (replaces try_files)
#   - /assets/* immutable year-long cache, no CSP
#   - /docs/* static CSP, 1h revalidation
#   - /api/v1/ws WebSocket proxy to backend:3001 (3600s read timeout)
#   - /api/* REST proxy to backend:3001
#   - shared security headers (X-Content-Type-Options, X-Frame-Options,
#     Referrer-Policy, Permissions-Policy, HSTS, templated CSP)
{
	auto_https off
	admin off
	servers :8080 {
		trusted_proxies static private_ranges
	}
	log {
		output stderr
		format json
	}
}

(security_headers) {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), camera=(), microphone=()"
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		-Server
		defer
	}
}

(spa_csp) {
	# Per-request CSP.  {http.request.uuid} is stable within a single
	# request, so the nonce value emitted into this header matches the
	# value the templates directive substitutes into index.html on the
	# same response.  Dual style-src directives mirror the old nginx
	# setup: style-src-elem locks <style> tags in modern browsers to the
	# per-request nonce; style-src 'unsafe-inline' is the fallback for
	# browsers without Level 3 support; style-src-attr 'unsafe-inline'
	# is required by Floating UI (Base UI) for positioning.
	header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'nonce-{http.request.uuid}' 'unsafe-inline'; style-src-elem 'self' 'nonce-{http.request.uuid}'; style-src-attr 'unsafe-inline'; connect-src 'self'; img-src 'self' data:; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" {
		defer
	}
}

(api_security_headers) {
	# Non-CSP security headers for proxied /api/* and /api/v1/ws routes.
	# Backend emits its own Content-Security-Policy and we pass it
	# through verbatim via reverse_proxy; no CSP is layered here so the
	# backend's JSON policy is not clobbered.  These other hardening
	# headers still apply to Caddy-generated error responses (502/504)
	# when the backend is unreachable.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), camera=(), microphone=()"
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		-Server
		defer
	}
}

:8080 {
	root * /usr/share/caddy/html

	# --- WebSocket proxy: must precede /api/* so it matches first ---
	@ws path /api/v1/ws
	handle @ws {
		import api_security_headers
		log_skip
		reverse_proxy backend:3001 {
			header_up Host {host}
			header_up X-Real-IP {client_ip}
			header_up X-Forwarded-For {client_ip}

			transport http {
				dial_timeout 5s
				write_timeout 30s
				read_timeout 3600s
			}
		}
	}

	# --- REST API proxy ---
	handle /api/* {
		import api_security_headers
		reverse_proxy backend:3001 {
			header_up Host {host}
			header_up X-Real-IP {client_ip}
			header_up X-Forwarded-For {client_ip}

			transport http {
				dial_timeout 5s
				write_timeout 30s
				read_timeout 30s
				keepalive 30s
			}
		}
	}

	# --- Immutable hashed assets (Vite content-hashed filenames) ---
	# Year-long immutable cache.  Deliberately no CSP -- the policy only
	# governs the document that loads these assets, so embedding a
	# per-request CSP nonce in an asset response would pin a stale nonce
	# into every cached copy.
	handle /assets/* {
		header {
			X-Content-Type-Options "nosniff"
			Strict-Transport-Security "max-age=63072000; includeSubDomains"
			Cache-Control "public, max-age=31536000, immutable"
			-Server
		}
		file_server {
			precompressed gzip
		}
	}

	# --- Bare /docs redirect to /docs/ for consistent trailing slash ---
	handle /docs {
		redir /docs/ permanent
	}

	# --- Static MkDocs documentation (no nonce) ---
	handle /docs/* {
		header {
			X-Content-Type-Options "nosniff"
			X-Frame-Options "DENY"
			Referrer-Policy "strict-origin-when-cross-origin"
			Permissions-Policy "geolocation=(), camera=(), microphone=()"
			Content-Security-Policy "default-src 'self'; script-src 'self'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'"
			Strict-Transport-Security "max-age=63072000; includeSubDomains"
			Cache-Control "public, max-age=3600"
			-Server
			defer
		}
		file_server {
			precompressed gzip
		}
	}

	# --- SPA / index.html: nonce substitution + no-cache + SPA fallback ---
	# No `precompressed` on this handler: the templates directive must see
	# the source index.html body to substitute the CSP nonce placeholder,
	# and precompressed would serve the .gz verbatim and skip templating.
	handle {
		import security_headers
		import spa_csp
		header Cache-Control "no-cache" {
			defer
		}
		try_files {path} /index.html
		templates
		file_server
	}
}
