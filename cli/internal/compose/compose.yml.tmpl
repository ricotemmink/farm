# Generated by SynthOrg CLI {{.CLIVersion}}
# Do not edit manually -- run 'synthorg init' to regenerate.

services:
{{- if postgresEnabled}}
  postgres:
    image: postgres:18-alpine
    ports:
      - "{{.PostgresPort}}:5432"
    volumes:
      - synthorg-pgdata:/var/lib/postgresql/data
    environment:
      POSTGRES_DB: synthorg
      POSTGRES_USER: synthorg
      POSTGRES_PASSWORD: {{yamlStr .PostgresPassword}}
      PGDATA: /var/lib/postgresql/data/pgdata
    user: "70:70"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=64m
      - /run/postgresql:noexec,nosuid,nodev,size=8m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 1G
          cpus: "1.0"
          pids: 128
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U synthorg -d synthorg"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 10s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end}}

  backend:
    image: {{digestPin "backend" "ghcr.io/aureliolo/synthorg-backend" .ImageTag}}
    ports:
      - "{{.BackendPort}}:3001"
    volumes:
      - synthorg-data:/data
{{- if .Sandbox}}
      # Docker socket: backend spawns ephemeral sandbox containers via
      # aiodocker. WARNING: root-equivalent access to the host Docker
      # daemon -- cap_drop/no-new-privileges/read_only below do NOT
      # contain socket-level privilege. Only enable in trusted hosts.
      - "{{.DockerSock}}:/var/run/docker.sock"
{{- end}}
{{- if postgresEnabled}}
    depends_on:
      postgres:
        condition: service_healthy
{{- end}}
    environment:
      SYNTHORG_HOST: "0.0.0.0"
      SYNTHORG_PORT: "3001"
{{- if postgresEnabled}}
      SYNTHORG_DATABASE_URL: {{yamlStr pgDSN}}
{{- else}}
      SYNTHORG_DB_PATH: "/data/synthorg.db"
{{- end}}
      SYNTHORG_MEMORY_DIR: "/data/memory"
      SYNTHORG_PERSISTENCE_BACKEND: {{yamlStr .PersistenceBackend}}
      SYNTHORG_MEMORY_BACKEND: {{yamlStr .MemoryBackend}}
      SYNTHORG_BUS_BACKEND: {{yamlStr .BusBackend}}
{{- if distributedEnabled}}
      SYNTHORG_NATS_URL: "nats://nats:4222"
{{- end}}
      SYNTHORG_LOG_DIR: "/data/logs"
      MEM0_TELEMETRY: "false"
      SYNTHORG_TELEMETRY: "{{if .TelemetryOptIn}}true{{else}}false{{end}}"
      SYNTHORG_LOG_LEVEL: {{yamlStr .LogLevel}}
{{- if .Sandbox}}
      SYNTHORG_SANDBOX_IMAGE: {{yamlStr (sandboxImageRef .ImageTag)}}
{{- end}}
{{- if .JWTSecret}}
      SYNTHORG_JWT_SECRET: {{yamlStr .JWTSecret}}
{{- end}}
{{- if .SettingsKey}}
      SYNTHORG_SETTINGS_KEY: {{yamlStr .SettingsKey}}
{{- end}}
    user: "65532:65532"
{{- if and .Sandbox (ge .DockerSockGID 0)}}
    # Supplementary group matches the host GID owning {{.DockerSock}}, so the
    # non-root backend user (65532) can read/write the mounted socket without
    # relaxing host-side permissions.
    group_add:
      - "{{.DockerSockGID}}"
{{- end}}
    # CIS Docker Benchmark v1.6.0 hardening (5.3, 5.12, 5.25, 5.28)
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=64m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 4G
          cpus: "2.0"
          pids: 256
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    # Healthcheck defined in Dockerfile -- do not override here.

  web:
    image: {{digestPin "web" "ghcr.io/aureliolo/synthorg-web" .ImageTag}}
    ports:
      - "{{.WebPort}}:8080"
    depends_on:
      backend:
        condition: service_healthy
    user: "65532:65532"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=16m
      - /config/caddy:noexec,nosuid,nodev,size=8m
      - /data/caddy:noexec,nosuid,nodev,size=16m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"
          pids: 64
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- if distributedEnabled}}

  # NATS JetStream service (distributed runtime).
  # Port layout: 3000 web / 3001 backend / 3002 reserved for DB / 3003 NATS client.
  # Monitoring endpoint (8222) is intentionally not mapped; use
  # `docker compose exec nats wget -qO- localhost:8222/varz` if needed.
  nats:
    image: nats:2.10-alpine
    command: ["-js", "-sd", "/data", "-m", "8222"]
    ports:
      - "{{.NatsClientPort}}:4222"
    volumes:
      - synthorg-nats-data:/data
    user: "1000:1000"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=16m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"
          pids: 64
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:8222/healthz"]
      interval: 10s
      timeout: 3s
      retries: 3
      start_period: 5s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end}}

networks:
  default:
    name: synthorg-net

volumes:
  synthorg-data:
{{- if postgresEnabled}}
  synthorg-pgdata:
{{- end}}
{{- if distributedEnabled}}
  synthorg-nats-data:
{{- end}}
