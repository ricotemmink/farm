# Generated by SynthOrg CLI {{.CLIVersion}}
# Do not edit manually -- run 'synthorg init' to regenerate.

services:
  backend:
    image: {{digestPin "backend" "ghcr.io/aureliolo/synthorg-backend" .ImageTag}}
    ports:
      - "{{.BackendPort}}:3001"
    volumes:
      - synthorg-data:/data
    environment:
      SYNTHORG_HOST: "0.0.0.0"
      SYNTHORG_PORT: "3001"
      SYNTHORG_DB_PATH: "/data/synthorg.db"
      SYNTHORG_MEMORY_DIR: "/data/memory"
      SYNTHORG_PERSISTENCE_BACKEND: {{yamlStr .PersistenceBackend}}
      SYNTHORG_MEMORY_BACKEND: {{yamlStr .MemoryBackend}}
      SYNTHORG_BUS_BACKEND: {{yamlStr .BusBackend}}
{{- if distributedEnabled}}
      SYNTHORG_NATS_URL: "nats://nats:4222"
{{- end}}
      SYNTHORG_LOG_DIR: "/data/logs"
      MEM0_TELEMETRY: "false"
      SYNTHORG_TELEMETRY: "{{if .TelemetryOptIn}}true{{else}}false{{end}}"
      SYNTHORG_LOG_LEVEL: {{yamlStr .LogLevel}}
{{- if .JWTSecret}}
      SYNTHORG_JWT_SECRET: {{yamlStr .JWTSecret}}
{{- end}}
{{- if .SettingsKey}}
      SYNTHORG_SETTINGS_KEY: {{yamlStr .SettingsKey}}
{{- end}}
    user: "65532:65532"
    # CIS Docker Benchmark v1.6.0 hardening (5.3, 5.12, 5.25, 5.28)
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=64m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 4G
          cpus: "2.0"
          pids: 256
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    # Healthcheck defined in Dockerfile -- do not override here.

  web:
    image: {{digestPin "web" "ghcr.io/aureliolo/synthorg-web" .ImageTag}}
    ports:
      - "{{.WebPort}}:8080"
    depends_on:
      backend:
        condition: service_healthy
    user: "101:101"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=16m
      - /var/cache/nginx:noexec,nosuid,nodev,size=32m
      - /var/run:noexec,nosuid,nodev,size=1m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"
          pids: 64
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- if distributedEnabled}}

  # NATS JetStream service (distributed runtime).
  # Port layout: 3000 web / 3001 backend / 3002 reserved for DB / 3003 NATS client.
  # Monitoring endpoint (8222) is intentionally not mapped; use
  # `docker compose exec nats wget -qO- localhost:8222/varz` if needed.
  nats:
    image: nats:2.10-alpine
    command: ["-js", "-sd", "/data", "-m", "8222"]
    ports:
      - "{{.NatsClientPort}}:4222"
    volumes:
      - synthorg-nats-data:/data
    user: "1000:1000"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=16m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"
          pids: 64
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:8222/healthz"]
      interval: 10s
      timeout: 3s
      retries: 3
      start_period: 5s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end}}
{{- if .Sandbox}}

  sandbox:
    image: {{digestPin "sandbox" "ghcr.io/aureliolo/synthorg-sandbox" .ImageTag}}
    depends_on:
      backend:
        condition: service_healthy
    volumes:
      - "{{.DockerSock}}:/var/run/docker.sock:ro"
    user: "10001:10001"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=128m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"
          pids: 128
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end}}

networks:
  default:
    name: synthorg-net

volumes:
  synthorg-data:
{{- if distributedEnabled}}
  synthorg-nats-data:
{{- end}}
