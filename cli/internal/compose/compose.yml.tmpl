# Generated by SynthOrg CLI {{.CLIVersion}}
# Do not edit manually -- run 'synthorg init' to regenerate.

services:
{{- if postgresEnabled}}
  postgres:
    # renovate: datasource=docker depName=dhi.io/postgres
    image: {{.DHIRegistry}}/postgres:{{.PostgresImageTag}}{{if .PostgresDigest}}@{{.PostgresDigest}}{{end}}
    ports:
      - "{{.PostgresPort}}:5432"
    volumes:
      - synthorg-pgdata:/var/lib/postgresql/data
    depends_on:
      data-init:
        condition: service_completed_successfully
    environment:
      PGDATA: /var/lib/postgresql/data
      POSTGRES_DB: synthorg
      POSTGRES_USER: synthorg
      POSTGRES_PASSWORD: {{yamlStr .PostgresPassword}}
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - DAC_OVERRIDE
      - FOWNER
      - SETGID
      - SETUID
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=64m
      - /run/postgresql:noexec,nosuid,nodev,size=8m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 1G
          cpus: "1.0"
          pids: 128
    healthcheck:
      test: ["CMD", "pg_isready", "-U", "synthorg", "-d", "synthorg"]
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 30s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end}}

  # Init container: chown named volumes to the correct non-root UID per service.
  # Fresh Docker named volumes are root-owned; DHI images run as non-root and
  # cannot self-chown, so this one-shot container sets ownership on first start.
  data-init:
    # renovate: datasource=docker depName=busybox
    image: busybox:1.37-musl@sha256:19b646668802469d968a05342a601e78da4322a414a7c09b1c9ee25165042138
    volumes:
      - synthorg-data:/data
{{- if postgresEnabled}}
      - synthorg-pgdata:/pgdata
{{- end}}
{{- if distributedEnabled}}
      - synthorg-nats-data:/nats-data
{{- end}}
    command: ["sh", "-c", "set -e; mkdir -p /data/logs /data/memory; chown -R 65532:65532 /data{{if postgresEnabled}}; chown -R 70:70 /pgdata; chmod 0700 /pgdata{{end}}{{if distributedEnabled}}; chown -R 65532:65532 /nats-data{{end}}"]
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - DAC_OVERRIDE
      - FOWNER

  backend:
    image: {{digestPin "backend" (printf "%s/%sbackend" .RegistryHost .ImageRepoPrefix) .ImageTag}}
    ports:
      - "{{.BackendPort}}:3001"
    volumes:
      - synthorg-data:/data
{{- if .Sandbox}}
      # Docker socket: backend spawns ephemeral sandbox containers via
      # aiodocker. WARNING: root-equivalent access to the host Docker
      # daemon -- cap_drop/no-new-privileges/read_only below do NOT
      # contain socket-level privilege. Only enable in trusted hosts.
      - "{{.DockerSock}}:/var/run/docker.sock"
{{- end}}
    depends_on:
      data-init:
        condition: service_completed_successfully
{{- if postgresEnabled}}
      postgres:
        condition: service_healthy
{{- end}}
    environment:
      SYNTHORG_HOST: "0.0.0.0"
      SYNTHORG_PORT: "3001"
{{- if postgresEnabled}}
      SYNTHORG_DATABASE_URL: {{yamlStr pgDSN}}
      # The local Postgres DHI image runs without TLS on the internal
      # docker network; default `require` mode would refuse the
      # connection. Override here so the backend can talk to it. For
      # production deployments, set this to `verify-full` and provide
      # certificate material.
      SYNTHORG_POSTGRES_SSL_MODE: "disable"
{{- else}}
      SYNTHORG_DB_PATH: "/data/synthorg.db"
{{- end}}
      SYNTHORG_MEMORY_DIR: "/data/memory"
      SYNTHORG_PERSISTENCE_BACKEND: {{yamlStr .PersistenceBackend}}
      SYNTHORG_MEMORY_BACKEND: {{yamlStr .MemoryBackend}}
      SYNTHORG_BUS_BACKEND: {{yamlStr .BusBackend}}
{{- if distributedEnabled}}
      SYNTHORG_NATS_URL: {{yamlStr .NATSURL}}
{{- end}}
      SYNTHORG_LOG_DIR: "/data/logs"
      MEM0_TELEMETRY: "false"
      SYNTHORG_TELEMETRY: "{{if .TelemetryOptIn}}true{{else}}false{{end}}"
      SYNTHORG_LOG_LEVEL: {{yamlStr .LogLevel}}
{{- if .Sandbox}}
      SYNTHORG_SANDBOX_IMAGE: {{yamlStr (sandboxImageRef .ImageTag)}}
      SYNTHORG_SIDECAR_IMAGE: {{yamlStr (sidecarImageRef .ImageTag)}}
{{- end}}
{{- if and .Sandbox .FineTuning}}
      SYNTHORG_FINE_TUNE_IMAGE: {{yamlStr (fineTuneImageRef .ImageTag)}}
{{- end}}
{{- if .JWTSecret}}
      SYNTHORG_JWT_SECRET: {{yamlStr .JWTSecret}}
{{- end}}
{{- if .SettingsKey}}
      SYNTHORG_SETTINGS_KEY: {{yamlStr .SettingsKey}}
{{- end}}
    user: "65532:65532"
{{- if and .Sandbox (ge .DockerSockGID 0)}}
    # Supplementary group matches the host GID owning {{.DockerSock}}, so the
    # non-root backend user (65532) can read/write the mounted socket without
    # relaxing host-side permissions.
    group_add:
      - "{{.DockerSockGID}}"
{{- end}}
    # CIS Docker Benchmark v1.6.0 hardening (5.3, 5.12, 5.25, 5.28)
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=64m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 4G
          cpus: "2.0"
          pids: 256
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    # Healthcheck defined in Dockerfile -- do not override here.

  web:
    image: {{digestPin "web" (printf "%s/%sweb" .RegistryHost .ImageRepoPrefix) .ImageTag}}
    ports:
      - "{{.WebPort}}:8080"
    depends_on:
      backend:
        condition: service_healthy
    user: "65532:65532"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=16m
      - /config/caddy:noexec,nosuid,nodev,size=8m
      - /data/caddy:noexec,nosuid,nodev,size=16m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"
          pids: 64
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- if distributedEnabled}}

  # DHI NATS: distroless, runs as nonroot (65532). Healthcheck via sidecar
  # because there is no shell or HTTP client inside the distroless image.
  # Configuration comes from a bind-mounted nats.conf written next to
  # compose.yml by the CLI -- NATS 2.12 has no `--max_payload` CLI flag,
  # so settings that diverge from defaults must come from a config file.
  nats:
    # renovate: datasource=docker depName=dhi.io/nats
    image: {{.DHIRegistry}}/nats:{{.NATSImageTag}}{{if .NATSDigest}}@{{.NATSDigest}}{{end}}
    command: ["-c", "/etc/nats/nats.conf"]
    ports:
      - "{{.NatsClientPort}}:4222"
    volumes:
      - synthorg-nats-data:/data
      - ./nats.conf:/etc/nats/nats.conf:ro
    depends_on:
      data-init:
        condition: service_completed_successfully
    user: "65532:65532"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,nodev,size=16m
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "0.5"
          pids: 64
  nats-healthcheck:
    # renovate: datasource=docker depName=busybox
    image: busybox:1.37-musl@sha256:19b646668802469d968a05342a601e78da4322a414a7c09b1c9ee25165042138
    depends_on:
      nats:
        condition: service_started
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://nats:8222/healthz"]
      interval: 10s
      timeout: 3s
      retries: 3
      start_period: 10s
    entrypoint: ["sleep", "infinity"]
    user: "65532:65532"
    read_only: true
    cap_drop:
      - ALL
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 8M
          cpus: "0.05"
          pids: 4
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{{- end}}

networks:
  default:
    name: synthorg-net

volumes:
  synthorg-data:
{{- if postgresEnabled}}
  synthorg-pgdata:
{{- end}}
{{- if distributedEnabled}}
  synthorg-nats-data:
{{- end}}
