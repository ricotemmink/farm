{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Data source scraping the SynthOrg /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "gauge",
      "id": 1,
      "title": "Coordination efficiency",
      "description": "Efficiency ratio (0.0-1.0) reported by CoordinationCollector after each multi-agent run.",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "synthorg_coordination_efficiency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"min": 0, "max": 1, "unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.8}]}}
      },
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0}
    },
    {
      "type": "gauge",
      "id": 2,
      "title": "Coordination overhead",
      "description": "Coordination overhead as a percentage of total execution time. Alert over 40%.",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "synthorg_coordination_overhead_percent",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"min": 0, "max": 100, "unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 25}, {"color": "red", "value": 40}]}}
      },
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0}
    },
    {
      "type": "gauge",
      "id": 3,
      "title": "Budget utilisation",
      "description": "Accumulated cost as % of monthly budget. Alert over 80%.",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "synthorg_budget_used_percent",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"min": 0, "max": 100, "unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 80}]}}
      },
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0}
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Escalation queue depth",
      "description": "Pending escalations by department. Sustained values > 5 indicate a backlog.",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(synthorg_escalation_queue_depth) by (department)",
          "legendFormat": "{{department}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0}
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Agent identity changes (rate / 5m)",
      "description": "Per-agent identity version changes: created / updated / rolled_back / archived.",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (change_type) (rate(synthorg_agent_identity_version_changes_total[5m]))",
          "legendFormat": "{{change_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Workflow execution duration p95",
      "description": "Workflow run latency quantile, labelled by terminal status.",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum by (le, status) (rate(synthorg_workflow_execution_seconds_bucket[5m])))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}
    },
    {
      "type": "table",
      "id": 7,
      "title": "Per-agent cost (current period)",
      "description": "Accumulated cost per agent in the configured currency.",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "topk(25, synthorg_agent_cost_total)",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 14}
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "API request rate by status class",
      "description": "Request rate per minute split into 2xx / 3xx / 4xx / 5xx.",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (status_class) (rate(synthorg_api_requests_total[1m]))",
          "legendFormat": "{{status_class}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 14}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["synthorg", "hyg-1"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": true, "text": "Prometheus", "value": "${DS_PROMETHEUS}"},
        "hide": 0
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "SynthOrg / Overview",
  "uid": "synthorg-overview",
  "version": 1,
  "weekStart": ""
}
